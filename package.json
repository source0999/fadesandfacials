{
  "name": "fades-and-facials",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "dev": "next dev",
    "build": "next build && node -e \"require('fs').writeFileSync(require('path').join('out','.nojekyll'),'')\"",
    "start": "next start",
    "lint": "next lint",
    "deploy": "gh-pages -d out"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "gh-pages": "^6.3.0"
  }
}
