{
  "name": "fades-and-facials",
  "private": true,
  "scripts": {
    "clean": "node -e \"require('fs').rmSync('.next',{recursive:true,force:true});\"",
    "clear-webpack-cache": "node -e \"try{require('fs').rmSync('.next/cache/webpack',{recursive:true,force:true})}catch(e){}\"",
    "dev": "next dev --turbopack",
    "dev:webpack": "next dev",
    "dev:turbo": "next dev --turbopack",
    "dev:clean": "npm run clean && next dev --turbopack",
    "build": "next build && node -e \"require('fs').writeFileSync(require('path').join('out','.nojekyll'),'')\"",
    "build:gh-pages": "cross-env GITHUB_ACTIONS=true npm run build",
    "start": "next start",
    "lint": "next lint",
    "deploy": "npm run build:gh-pages && gh-pages -d out"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lenis": "^1.3.21",
    "lucide-react": "^1.7.0",
    "next": "^15.5.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sharp": "^0.34.5"
  },
  "devDependencies": {
    "cross-env": "^7.0.3",
    "eslint": "^8.57.1",
    "eslint-config-next": "^15.5.14",
    "gh-pages": "^6.3.0"
  }
}
